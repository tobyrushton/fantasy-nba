---
import Layout from "@/layouts/main.astro"
import { Client } from "@/client/api"
import { PlayersExplorer } from "@/components/players-explorer"

const client = new Client(import.meta.env.API_URL)

const players = await client.getPlayers()
---

<Layout>
  <main class="relative min-h-svh overflow-hidden p-4 md:p-10">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(140deg,#f8fafc_0%,#eff6ff_48%,#fffbeb_100%)]" />
    <div class="mx-auto w-full">
      <PlayersExplorer client:load players={players} />
    </div>
  </main>
</Layout>
